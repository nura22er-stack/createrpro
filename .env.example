# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# YOUTUBE_API_KEY / GOOGLE_API_KEY: Used for Google and YouTube API requests.
# Keep real keys only in .env.local.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"
GOOGLE_API_KEY="MY_GOOGLE_API_KEY"

# YouTube OAuth upload connection. Create these in Google Cloud Console.
YOUTUBE_CLIENT_ID="MY_YOUTUBE_CLIENT_ID"
YOUTUBE_CLIENT_SECRET="MY_YOUTUBE_CLIENT_SECRET"
YOUTUBE_REDIRECT_URI="http://localhost:8787/auth/youtube/callback"
SERVER_PORT="8787"

# AI agent upload visibility: public, unlisted, or private.
AGENT_PRIVACY_STATUS="public"

# AI agent cadence. Default is one upload every 5 minutes.
AGENT_UPLOAD_INTERVAL_MS="300000"
AGENT_OUTPUT_WIDTH="720"
AGENT_OUTPUT_HEIGHT="1280"
AGENT_SHORT_DURATION_SECONDS="18"
AGENT_YOUTUBE_CATEGORY_ID="24"

# Optional comma/newline-separated rights-safe source video URLs.
# Use only videos you own, have permission to reuse, or that are public-domain/Creative Commons.
AGENT_SOURCE_URLS=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
